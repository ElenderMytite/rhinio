// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "adapter": "CodeLLDB",
    "args": ["vector.txt"],
    "label": "cargo test -p tinywrite --all-targets",
    "build": {
      "label": "cargo test -p tinywrite --all-targets",
      "command": "cargo",
      "args": [
        "test",
        "--package",
        "tinywrite",
        "--all-targets",
        "--no-run",
        "vector.txt",
      ],
      "env": {
        "RUSTC_TOOLCHAIN": "/home/ghost-tornado/.rustup/toolchains/stable-x86_64-unknown-linux-gnu",
      },
      "cwd": "/home/ghost-tornado/projects/rust/tinywrite",
      "use_new_terminal": false,
      "allow_concurrent_runs": false,
      "reveal": "always",
      "reveal_target": "dock",
      "hide": "never",
      "shell": "system",
      "show_summary": false,
      "show_command": false,
      "save": "none",
    },
    "sourceLanguages": ["rust"],
  },
]
